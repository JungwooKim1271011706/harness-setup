{
  "agent": "orchestrator",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/harness-check-backstop.sh --seed",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-orchestrator-exec.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-products-main-push.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-orchestrator-edit.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-developer-test-edit.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "planner-backend|planner-frontend|planner-high-complexity",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-planner-output.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "finalizer",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-finalizer-output.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/harness-check-backstop.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
